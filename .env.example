# E16 LMS Configuration Example
# Copy this file to .env and fill in the values for production

# --- Core Security ---
SECRET_KEY=generate-a-secure-random-key-here
FLASK_DEBUG=false

# --- Database ---
# For SQLite (local dev): sqlite:///e16.db
# For PostgreSQL (production): postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///e16.db

# --- Demo Data Seeding ---
# This password will be used for all seeded accounts (student1, teacher, admin)
E16_SEED_PASSWORD=change-this-to-something-secure

# --- Server Port ---
PORT=5000
